generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id                 String   @id @default(cuid())
  name               String
  medicationsEnabled Boolean  @default(true)
  houses             House[]
  users              User[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model House {
  id             String       @id @default(cuid())
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  participants   Participant[]
  users          User[]       // Staff assigned to this house
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model User {
  id             String       @id @default(cuid())
  name           String
  email          String       @unique
  emailVerified  Boolean      @default(false)
  image          String?
  role           Role         @default(SUPPORT_WORKER)
  organization   Organization @relation(fields: [organizationId], references: [id])
  organizationId String
  houses         House[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  taskLogs       TaskLog[]
  sessions       Session[]
  accounts       Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  @@map("session")
}

model Account {
  id           String    @id @default(cuid())
  accountId    String
  providerId   String
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken  String?
  refreshToken String?
  idToken      String?
  expiresAt    DateTime?
  password     String?
  createdAt    DateTime? @default(now())
  updatedAt    DateTime? @updatedAt

  @@map("account")
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime? @default(now())
  updatedAt  DateTime? @updatedAt

  @@map("verification")
}

enum Role {
  SUPPORT_WORKER
  TEAM_LEADER
  ADMIN
}

model Participant {
  id             String       @id @default(cuid())
  fullName       String
  preferredName  String?
  photoUrl       String?
  dob            DateTime
  house          House        @relation(fields: [houseId], references: [id])
  houseId        String
  medicalAlerts  String?      // Simple text for now
  active         Boolean      @default(true)
  
  appointments   Appointment[]
  medications    Medication[]
  routines       Routine[]
  alerts         ParticipantAlert[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model ParticipantAlert {
  id            String      @id @default(cuid())
  participant   Participant @relation(fields: [participantId], references: [id])
  participantId String
  message       String
  severity      Severity    @default(MEDIUM)
  createdAt     DateTime    @default(now())
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Appointment {
  id              String       @id @default(cuid())
  participant     Participant  @relation(fields: [participantId], references: [id])
  participantId   String
  title           String
  type            String?      // e.g. Medical, Social, Therapy
  providerName    String?
  location        String?
  dateTime        DateTime
  leaveTime       DateTime?
  transportReq    Boolean      @default(false)
  transportNotes  String?
  escortReq       Boolean      @default(false)
  prepNotes       String?
  status          ApptStatus   @default(UPCOMING)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

enum ApptStatus {
  UPCOMING
  ATTENDED
  CANCELLED
  RESCHEDULED
}

model Medication {
  id              String       @id @default(cuid())
  participant     Participant  @relation(fields: [participantId], references: [id])
  participantId   String
  name            String
  dosage          String
  instructions    String?
  timeDue         String       // e.g. "08:00"
  isCritical      Boolean      @default(false)
  logs            TaskLog[]
}

model Routine {
  id              String       @id @default(cuid())
  participant     Participant  @relation(fields: [participantId], references: [id])
  participantId   String
  title           String
  description     String?
  frequency       String       // e.g. DAILY, WEEKLY, MON-FRI
  timeDue         String?      // e.g. "09:00"
  logs            TaskLog[]
}

model TaskLog {
  id              String       @id @default(cuid())
  user            User         @relation(fields: [userId], references: [id])
  userId          String
  participantId   String
  medicationId    String?
  medication      Medication?  @relation(fields: [medicationId], references: [id])
  routineId       String?
  routine         Routine?     @relation(fields: [routineId], references: [id])
  status          String       // DONE, SKIPPED, DELAYED
  notes           String?
  timestamp       DateTime     @default(now())
}
